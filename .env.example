# StackTrace Environment Variables
# Copy this file to .env and fill in actual values.
# Never commit .env to version control.

# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://stacktrace:password@localhost:5432/stacktrace

# Connection pool size for the API server
DATABASE_POOL_SIZE=10

# =============================================================================
# SEC EDGAR API
# =============================================================================

# EDGAR requires a User-Agent header with your name and email
# SEC will block requests without a proper User-Agent
# Format: "CompanyName admin@company.com"
SEC_EDGAR_USER_AGENT=StackTrace your-email@example.com

# =============================================================================
# IMPORTYETI
# =============================================================================

# ImportYeti does not require an API key for basic access
# Base URL for scraping/API access
IMPORTYETI_BASE_URL=https://www.importyeti.com

# =============================================================================
# USASPENDING.GOV API
# =============================================================================

# USASpending does not require an API key
# Base URL for API access
USASPENDING_BASE_URL=https://api.usaspending.gov

# =============================================================================
# USPTO PATENTSVIEW API
# =============================================================================

# PatentsView does not require an API key
# Base URL for API access
USPTO_PATENTSVIEW_BASE_URL=https://api.patentsview.org

# =============================================================================
# CLAUDE API (ANTHROPIC)
# =============================================================================

# Anthropic API key for Claude — used for LLM extraction and classification
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Model to use for extraction tasks (e.g., claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Maximum tokens per extraction request
ANTHROPIC_MAX_TOKENS=4096

# =============================================================================
# API SERVER
# =============================================================================

# Port the Node.js API server listens on
API_PORT=3001

# Environment: development, staging, production
NODE_ENV=development

# Secret key for signing JWT tokens (generate a random 64-char hex string)
JWT_SECRET=your-jwt-secret-here

# JWT token expiration (e.g., 7d, 24h)
JWT_EXPIRATION=7d

# =============================================================================
# FRONTEND
# =============================================================================

# Port the React dev server runs on
FRONTEND_PORT=3000

# API base URL the frontend calls
REACT_APP_API_URL=http://localhost:3001

# =============================================================================
# STRIPE (BILLING)
# =============================================================================

# Stripe API keys for subscription billing
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Stripe Price IDs for each tier
STRIPE_PRICE_PRO=price_xxxxx
STRIPE_PRICE_PREMIUM=price_xxxxx

# =============================================================================
# EMAIL (ALERTS)
# =============================================================================

# SMTP or transactional email service for alert notifications
# Supports: sendgrid, ses, smtp
EMAIL_PROVIDER=sendgrid

# SendGrid API key (if using SendGrid)
SENDGRID_API_KEY=SG.xxxxx

# From address for alert emails
EMAIL_FROM=alerts@stacktrace.app

# =============================================================================
# CACHING
# =============================================================================

# Redis connection URL for caching layer
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds for search results (default: 24 hours)
CACHE_TTL=86400

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# RATE LIMITING
# =============================================================================

# Requests per minute per IP for unauthenticated endpoints
RATE_LIMIT_PUBLIC=10

# Requests per minute per user for authenticated endpoints
RATE_LIMIT_AUTHENTICATED=60
